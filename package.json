    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/throttler": "^6.2.0",
    "@prisma/client": "^5.18.0",
    "apify-client": "^2.9.0",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.0",
    "openai": "^4.55.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "pino": "^9.3.2",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "puppeteer": "^23.0.0",
